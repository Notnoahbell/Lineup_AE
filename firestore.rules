rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // One leaderboard doc per user, keyed by their Firebase Auth uid (see
    // js/leaderboard.js — signed in via Google, not anonymous or a plain
    // password). Public read so everyone can see the board without signing
    // in; write is restricted to a client writing its OWN doc, from a
    // VERIFIED @thinkingbox.com account, with basic shape/type/size
    // validation on top — a CEP panel can't keep its API key/OAuth client
    // secret confidential, so these rules (not those values) are the only
    // real enforcement boundary. email_verified/email are populated by
    // Firebase from Google's own token regardless of provider, so this
    // logic didn't need to change when the sign-in method did.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.auth.token.email_verified == true
                   && request.auth.token.email.matches('.*@thinkingbox[.]com$')
                   && request.resource.data.keys().hasOnly(['name', 'score', 'scoreDaily', 'scoreWeekly', 'scoreMonthly', 'streakCurrent', 'streakBest', 'updatedAt'])
                   && request.resource.data.name is string
                   && request.resource.data.name.size() > 0
                   && request.resource.data.name.size() <= 40
                   && request.resource.data.score is int
                   && request.resource.data.score >= 0
                   && request.resource.data.scoreDaily is int
                   && request.resource.data.scoreDaily >= 0
                   && request.resource.data.scoreWeekly is int
                   && request.resource.data.scoreWeekly >= 0
                   && request.resource.data.scoreMonthly is int
                   && request.resource.data.scoreMonthly >= 0
                   && request.resource.data.streakCurrent is int
                   && request.resource.data.streakCurrent >= 0
                   && request.resource.data.streakBest is int
                   && request.resource.data.streakBest >= 0;
    }

    // The FULL per-day activity history (time/keyframes/layers/exports —
    // see js/leaderboard.js's push/pull/merge), used to restore/merge a
    // user's progress across machines. Unlike `leaderboard` above, this is
    // NOT public — only the owning, verified @thinkingbox.com uid can read
    // or write it at all, since it's private activity data, not a public
    // ranked list. No field-shape validation on `history` itself (it's a
    // dynamically-keyed map of arbitrary date strings, which rules can't
    // usefully enumerate) — the only client that can ever write here is the
    // account owner's own, so the risk profile is much lower than the
    // public-write `leaderboard` collection above.
    match /activityData/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && request.auth.token.email_verified == true
                         && request.auth.token.email.matches('.*@thinkingbox[.]com$');
    }
  }
}
